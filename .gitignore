# ==============================================================================
# 🦀 Rust / Cargo Build Artifacts
# ==============================================================================
/target/

# ==============================================================================
# 🍞 JS / Bun / Svelte Frontend Build Artifacts
# ==============================================================================
# Third-party dependency directories (Crucial to ignore!)
node_modules/
jspm_packages/
.npm/

# Vite production build output
dist/
dist-ssr/

# Log files generated by JS package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# TypeScript incremental compilation cache
*.tsbuildinfo

# ==============================================================================
# 🔒 Environment Secrets & Configuration
# ==============================================================================
.env
.env.*
!.env.example

# ==============================================================================
# 🗄️ Local Databases & Data Directories
# ==============================================================================
# SQLite telemetry files
*.db
*.sqlite
*.sqlite-journal

# Docker postgres volume data (if used in future phases)
postgres_data/

# ==============================================================================
# 🖥️ System & Editor Specific Files
# ==============================================================================
# OS Files
.DS_Store
Thumbs.db

# VS Code / IntelliJ settings
.vscode/
.idea/

# Editor temp files
*.swp

# Application Log files
*.log

# Compiled Binary executables/libraries
*.exe
*.dll
*.so
*.dylib